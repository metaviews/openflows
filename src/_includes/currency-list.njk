{% set strings = i18n[lang or 'en'] %}
{% if items and items.length %}
{% if lang == 'zh' %}
<p class="meta">共 {{ items.length }} 条目，{{ strings.list.sorted }}</p>
{% else %}
<p class="meta">{{ items.length }} entr{% if items.length == 1 %}y{% else %}ies{% endif %}. {{ strings.list.sorted }}</p>
{% endif %}
<ul class="currency-list">
  {% for item in items %}
  <li>
    <a href="{{ item.url }}">{{ item.data.title }}</a>
    {% if item.data.abstract %}
    <p class="item-abstract">{{ item.data.abstract }}</p>
    {% endif %}
    <div class="item-meta">
      <span class="chip">{{ item.data.currencyType | typeLabel(lang) }}</span>
      <span class="chip">{{ item.data.lang or 'en' }}</span>
      <span class="muted">{{ item.date | readableDate }}</span>
      {% set counterpart = collections.allCurrency | currencyCounterpart(item.data.currencyId, item.data.lang) %}
      {% if not counterpart %}
      <span class="chip alert">
        {% if item.data.lang == 'zh' %}{{ strings.browser.missing_en }}{% else %}{{ strings.browser.missing_zh }}{% endif %}
      </span>
      {% endif %}
    </div>
  </li>
  {% endfor %}
</ul>
{% else %}
<p>{{ strings.list.no_entries }}</p>
{% endif %}
