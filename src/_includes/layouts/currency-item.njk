---
layout: layouts/base.njk
---
{% set strings = i18n[lang or 'en'] %}
{% set entryLang = lang or 'en' %}
{% set backlinks = collections.allCurrency | currencyBacklinks(currencyId, entryLang) %}
{% set references = content | externalLinks %}

<article class="entry-shell">
  <header class="entry-header">
    <p class="hero-kicker">{{ currencyType | typeLabel(lang) }}</p>
    <h2>{{ title }}</h2>
    {% if abstract %}<p class="item-abstract">{{ abstract }}</p>{% endif %}
    <div class="entry-meta-grid">
      <div class="entry-meta-item">
        <span>{{ strings.entry.currency_id }}</span>
        <strong>{{ currencyId }}</strong>
      </div>
      <div class="entry-meta-item">
        <span>{{ strings.entry.date }}</span>
        <strong>{{ date | readableDate }}</strong>
      </div>
      <div class="entry-meta-item">
        <span>{{ strings.entry.language }}</span>
        <strong>{% if entryLang == 'zh' %}{{ strings.browser.chinese }}{% else %}{{ strings.browser.english }}{% endif %}</strong>
      </div>
      {% if lastReviewed %}
      <div class="entry-meta-item">
        <span>{{ strings.entry.last_reviewed }}</span>
        <strong>{{ lastReviewed | readableDate }}</strong>
      </div>
      {% endif %}
    </div>
  </header>

  <div class="entry-body">
    {{ content | safe }}
  </div>
</article>

{% if links and links.length %}
<section class="connection-note">
  <h3>{{ strings.entry.connections }}</h3>
  <ul class="connection-list">
    {% for link in links %}
    {% set target = collections.allCurrency | currencyByIdForLang(link.id, entryLang) %}
    {% if target %}
    <li>
      <a href="{{ target.url }}">{{ target.data.title }}</a>
      {% if link.relation %}<span class="muted"> - {{ link.relation }}</span>{% endif %}
      <span class="muted">({{ target.data.currencyType | typeLabel(lang) }} · {{ target.data.lang or 'en' }})</span>
    </li>
    {% else %}
    <li><span class="muted">{{ strings.entry.missing_connection }}: {{ link.id }}</span></li>
    {% endif %}
    {% endfor %}
  </ul>
</section>
{% endif %}

{% if backlinks and backlinks.length %}
<section class="connection-note">
  <h3>{{ strings.entry.backlinks }}</h3>
  <ul class="connection-list">
    {% for item in backlinks %}
    <li>
      <a href="{{ item.url }}">{{ item.data.title }}</a>
      <span class="muted">({{ item.data.currencyType | typeLabel(lang) }})</span>
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}

{% if references and references.length %}
<section class="connection-note">
  <h3>{{ strings.entry.references }}</h3>
  <ul class="connection-list">
    {% for reference in references %}
    <li><a href="{{ reference.url }}" rel="noopener">{{ reference.label }}</a></li>
    {% endfor %}
  </ul>
</section>
{% endif %}

{% if mediation %}
<section class="mediation-note">
  <h3>{{ strings.entry.mediation_note }}</h3>
  <p><strong>{{ strings.entry.tooling }}:</strong> {{ mediation.tooling }}</p>
  {% if mediation.use and mediation.use.length %}
  <p><strong>{{ strings.entry.use }}:</strong> {{ mediation.use | join(", ") }}</p>
  {% endif %}
  <p><strong>{{ strings.entry.human_role }}:</strong> {{ mediation.humanRole }}</p>
  <p><strong>{{ strings.entry.limits }}:</strong> {{ mediation.limits }}</p>
</section>
{% endif %}
