<!doctype html>
<html lang="{{ lang or 'en' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Openflows" }}{% if title and title != "Openflows" %} — Openflows{% endif %}</title>

  {% set pageTitle = title or metadata.title %}
  {% set pageDescription = abstract or metadata.description %}
  {% set pageUrl = metadata.url + page.url %}
  {% set pageImage = metadata.url + metadata.image %}

  <meta name="description" content="{{ pageDescription }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="Openflows">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:image" content="{{ pageImage }}">
  <meta property="og:type" content="{% if currencyType %}article{% else %}website{% endif %}">
  {% if lang == 'zh' %}
  <meta property="og:locale" content="zh_CN">
  <meta property="og:locale:alternate" content="en_US">
  {% else %}
  <meta property="og:locale" content="en_US">
  <meta property="og:locale:alternate" content="zh_CN">
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ pageImage }}">

  <link rel="alternate" type="application/rss+xml" title="Openflows Currency RSS" href="/currency/feed.xml">
  <link rel="alternate" type="application/feed+json" title="Openflows Currency JSON Feed" href="/currency/feed.json">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-F7DCVTHTKE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());

    gtag('config', 'G-F7DCVTHTKE');
  </script>
  <style>
    :root {
      --bg: #f4f7f8;
      --surface: #ffffff;
      --surface-2: #eaf1f2;
      --ink: #101417;
      --muted: #53616a;
      --line: #bdcbd0;
      --panel: #dfeaec;
      --accent: #0b6b61;
      --accent-2: #b3382c;
      --accent-3: #2467a0;
      --shadow: 0 16px 48px rgba(17, 30, 37, 0.12);
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    body {
      margin: 0;
      background:
        linear-gradient(180deg, #dce8ea 0, var(--bg) 22rem),
        var(--bg);
      color: var(--ink);
      font-family: Georgia, "Times New Roman", serif;
      line-height: 1.6;
    }
    :lang(zh) body, :lang(zh) {
      font-family: "Noto Serif SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Palatino Linotype", serif;
    }
    .wrap {
      max-width: 78rem;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }
    header.site-header {
      padding: 1.1rem 0 1rem;
      border-bottom: 1px solid rgba(16, 20, 23, 0.16);
      margin-bottom: 1.5rem;
    }
    .header-row {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--ink);
      font-weight: 700;
      letter-spacing: 0;
    }
    .brand-logo {
      display: block;
      width: 52px;
      height: 52px;
      object-fit: contain;
      border-radius: 4px;
    }
    .footer-brand .brand-logo {
      width: 44px;
      height: 44px;
    }
    h1, h2, h3 {
      line-height: 1.18;
      letter-spacing: 0;
      overflow-wrap: anywhere;
    }
    h1 { margin: 0; font-size: 1.7rem; }
    h2 { margin-top: 2rem; }
    h3 { margin-top: 1.4rem; }
    main {
      max-width: 58rem;
      margin: 0 auto;
    }
    main > p, main > ul, main > ol, main > article, main > h2, main > h3 {
      max-width: 48rem;
    }
    a { color: var(--accent); text-underline-offset: 0.15em; }
    a:hover { color: var(--accent-2); }
    nav {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.35rem;
      flex-wrap: wrap;
      font-family: Arial, "Helvetica Neue", sans-serif;
    }
    nav a {
      color: var(--ink);
      text-decoration: none;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 0.35rem 0.55rem;
      font-size: 0.92rem;
      line-height: 1.2;
    }
    nav a:hover {
      border-color: var(--line);
      background: rgba(255, 255, 255, 0.7);
      color: var(--ink);
    }
    .lang-switch {
      border-color: var(--line);
      background: var(--surface);
      color: var(--accent);
    }
    hr { display: none; }
    .muted { color: var(--muted); }
    .meta {
      margin: 0.25rem 0 1rem;
      font-size: 0.95rem;
      color: var(--muted);
    }
    .chip {
      display: inline-block;
      padding: 0.12rem 0.48rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      font-size: 0.78rem;
      background: var(--surface);
      text-transform: capitalize;
      letter-spacing: 0;
      font-family: Arial, "Helvetica Neue", sans-serif;
      line-height: 1.25;
    }
    .chip.alert {
      border-color: rgba(179, 56, 44, 0.35);
      color: var(--accent-2);
      background: #fff1ef;
    }
    .hero-panel, .section-band, .browser-panel, .entry-shell {
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.86);
      box-shadow: var(--shadow);
      border-radius: 8px;
    }
    .section-band {
      max-width: none;
      padding: 1rem;
      margin: 1.25rem 0 1.75rem;
    }
    .hero-panel {
      max-width: none;
      padding: 1.4rem;
      margin: 0 0 1.5rem;
      display: grid;
      gap: 1.25rem;
      grid-template-columns: 1fr;
    }
    .hero-kicker {
      color: var(--accent-2);
      font-family: Arial, "Helvetica Neue", sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0;
      text-transform: uppercase;
      margin: 0 0 0.45rem;
    }
    .hero-panel h2,
    .hero-panel h1 {
      margin: 0;
      font-size: clamp(2rem, 7vw, 4rem);
      line-height: 1.03;
    }
    .hero-panel p {
      font-size: 1.08rem;
      margin: 0.75rem 0 0;
      max-width: 46rem;
    }
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      align-content: start;
    }
    .stat {
      border: 1px solid var(--line);
      background: var(--surface);
      border-radius: 8px;
      padding: 0.7rem;
      min-height: 5.3rem;
    }
    .stat strong {
      display: block;
      font-family: Arial, "Helvetica Neue", sans-serif;
      font-size: 1.55rem;
      line-height: 1.1;
    }
    .stat span {
      color: var(--muted);
      font-size: 0.86rem;
    }
    .currency-list {
      list-style: none;
      margin: 0.65rem 0 0;
      padding: 0;
    }
    .currency-list li {
      padding: 0.85rem 0;
      border-top: 1px solid var(--line);
    }
    .currency-list li:last-child { border-bottom: 1px solid var(--line); }
    .currency-list a {
      font-weight: 700;
      overflow-wrap: anywhere;
    }
    .item-meta {
      margin-top: 0.2rem;
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .item-abstract {
      margin: 0.35rem 0 0;
      color: var(--muted);
      line-height: 1.45;
    }
    .grid-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
      gap: 1rem;
      margin: 1rem 0 0;
      max-width: none;
    }
    .hub-card {
      border: 1px solid var(--line);
      background: var(--surface);
      border-radius: 8px;
      padding: 1rem;
      min-height: 11rem;
    }
    .hub-card h3 {
      margin-top: 0;
      margin-bottom: 0.4rem;
    }
    .hub-card p {
      margin-top: 0.4rem;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-top: 0.75rem;
    }
    .feature-panel {
      border: 1px solid var(--line);
      background: #fcfbf8;
      padding: 0.9rem 1rem;
    }
    .feature-panel h3 {
      margin-top: 0;
      margin-bottom: 0.35rem;
    }
    .feature-list {
      list-style: none;
      margin: 0.5rem 0 0;
      padding: 0;
    }
    .feature-list li {
      padding: 0.55rem 0;
      border-top: 1px solid var(--line);
    }
    .feature-list li:first-child {
      border-top: 0;
      padding-top: 0.2rem;
    }
    @media (min-width: 760px) {
      .feature-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    .mediation-note {
      border: 1px solid var(--line);
      padding: 0.9rem 1rem;
      margin-top: 1.25rem;
      background: var(--panel);
      border-radius: 8px;
    }
    .connection-note {
      border: 1px solid var(--line);
      padding: 0.9rem 1rem;
      margin-top: 1.25rem;
      background: var(--surface);
      border-radius: 8px;
    }
    .connection-list {
      margin: 0.6rem 0 0;
      padding-left: 1.1rem;
    }
    .currency-section {
      margin-top: 1.75rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--line);
    }
    .currency-section:first-of-type {
      border-top: 0;
      padding-top: 0;
      margin-top: 1rem;
    }
    .currency-section-header {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }
    .currency-section-header h2 {
      margin: 0;
    }
    .entry-count {
      font-size: 0.88rem;
    }
    .filter-bar {
      display: grid;
      gap: 0.75rem;
      margin: 0.9rem 0 0.25rem;
    }
    .filter-bar input,
    .filter-bar select {
      width: 100%;
      padding: 0.62rem 0.7rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      font-family: Arial, "Helvetica Neue", sans-serif;
      font-size: 0.95rem;
      color: var(--ink);
      outline: none;
    }
    .filter-bar input:focus,
    .filter-bar select:focus {
      border-color: var(--accent);
    }
    .filter-bar select:disabled,
    .browser-controls select:disabled {
      color: var(--muted);
      background: var(--surface-2);
    }
    .browser-panel {
      max-width: none;
      margin: 1.25rem 0 1.75rem;
      padding: 1rem;
    }
    .browser-panel h2 {
      margin: 0;
    }
    .browser-controls {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .browser-results {
      display: grid;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .browser-result {
      border: 1px solid var(--line);
      background: var(--surface);
      border-radius: 8px;
      padding: 0.85rem;
    }
    .browser-result h3 {
      margin: 0 0 0.35rem;
      font-size: 1.1rem;
    }
    .browser-result p {
      margin: 0.4rem 0;
    }
    .entry-shell {
      max-width: none;
      padding: 1.2rem;
    }
    .entry-header h2 {
      margin: 0.3rem 0 0.75rem;
      font-size: clamp(2rem, 6vw, 3.4rem);
    }
    .entry-meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
      gap: 0.65rem;
      margin: 1rem 0 1.2rem;
      font-family: Arial, "Helvetica Neue", sans-serif;
    }
    .entry-meta-item {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 0.6rem;
      background: var(--surface);
      min-width: 0;
    }
    .entry-meta-item span {
      display: block;
      color: var(--muted);
      font-size: 0.78rem;
      margin-bottom: 0.15rem;
    }
    .entry-meta-item strong,
    .entry-meta-item a {
      overflow-wrap: anywhere;
    }
    .entry-body {
      max-width: 48rem;
    }
    .entry-body img,
    main img {
      max-width: 100%;
      height: auto;
    }
    pre, code {
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }
    footer {
      margin-top: 2.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--line);
    }
    .footer-links {
      margin-top: 0.55rem;
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
      font-size: 0.95rem;
    }
    @media (min-width: 720px) {
      .hero-panel {
        grid-template-columns: minmax(0, 1.7fr) minmax(16rem, 0.8fr);
        padding: 1.8rem;
      }
      .browser-controls {
        grid-template-columns: minmax(0, 2fr) minmax(10rem, 0.7fr) minmax(10rem, 0.7fr);
      }
      .browser-results {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .filter-bar {
        grid-template-columns: minmax(0, 1fr) minmax(10rem, 0.4fr);
      }
    }
    @media (max-width: 640px) {
      .wrap { padding-left: 0.75rem; padding-right: 0.75rem; }
      nav { justify-content: flex-start; }
      .stat-grid { grid-template-columns: 1fr; }
      .hero-panel, .entry-shell, .browser-panel { padding: 1rem; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="site-header">
      <div class="header-row">
        <h1>
          {% if lang == 'zh' %}
          <a href="/zh/" class="brand">
          {% else %}
          <a href="/" class="brand">
          {% endif %}
            <img src="/assets/img/openflowslogo.jpg" alt="Openflows logo" class="brand-logo">
            <span>Openflows</span>
          </a>
        </h1>
      <nav>
        {% if lang == 'zh' %}
          <a href="/zh/currency/">流通</a>
          <a href="/about/">关于</a>
          <a href="/contact/">联系</a>
          {% if currencyId %}
            {% set langTarget = collections.allCurrency | currencyCounterpart(currencyId, lang) %}
            {% if langTarget %}
              <a href="{{ langTarget.url }}" class="lang-switch">English</a>
            {% else %}
              <a href="{{ page.url | replace('/zh/', '/') }}" class="lang-switch">English</a>
            {% endif %}
          {% else %}
            {% if page.url | startsWith('/zh/currency/') %}
              <a href="{{ page.url | replace('/zh/', '/') }}" class="lang-switch">English</a>
            {% else %}
              <a href="/" class="lang-switch">English</a>
            {% endif %}
          {% endif %}
        {% else %}
          <a href="/system/">System</a>
          <a href="/methods/">Methods</a>
          <a href="/currency/">Currency</a>
          <a href="/perspective/">Perspective</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          {% if currencyId %}
            {% set langTarget = collections.allCurrency | currencyCounterpart(currencyId, lang) %}
            {% if langTarget %}
              <a href="{{ langTarget.url }}" class="lang-switch">中文</a>
            {% else %}
              <a href="/zh{{ page.url }}" class="lang-switch">中文</a>
            {% endif %}
          {% else %}
            {% if page.url == "/" %}
              <a href="/zh/" class="lang-switch">中文</a>
            {% elif page.url | startsWith('/currency/') %}
              <a href="/zh{{ page.url }}" class="lang-switch">中文</a>
            {% else %}
              <a href="/zh/" class="lang-switch">中文</a>
            {% endif %}
          {% endif %}
        {% endif %}
      </nav>
      </div>
      <hr>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      {% if lang == 'zh' %}
      <a href="/zh/" class="brand footer-brand">
      {% else %}
      <a href="/" class="brand footer-brand">
      {% endif %}
        <img src="/assets/img/openflowslogo.jpg" alt="Openflows logo" class="brand-logo">
        <span>Openflows</span>
      </a>
      <div class="footer-links">
        {% if lang == 'zh' %}
          <a href="/about/">关于</a>
          <a href="/contact/">联系</a>
        {% else %}
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        {% endif %}
      </div>
      {% if lang == 'zh' %}
      <p style="margin-top:1rem;font-size:0.85rem;color:var(--muted);">
        本站中文内容由机器翻译生成，仅供参考。如发现翻译问题，请联系 <a href="mailto:openflows@gmail.com">openflows@gmail.com</a>。
      </p>
      {% endif %}
      <div style="margin-top:1.25rem;">
        <a href="https://metaviews.ca" rel="noopener">
          <img src="/assets/img/logowide-cherry.png" alt="Metaviews" style="height:36px;width:auto;display:block;">
        </a>
      </div>
    </footer>
  </div>
</body>
</html>
