<!doctype html>
<html lang="{{ lang or 'en' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Openflows" }}{% if title and title != "Openflows" %} — Openflows{% endif %}</title>

  {% set pageTitle = title or metadata.title %}
  {% set pageDescription = abstract or metadata.description %}
  {% set pageUrl = metadata.url + page.url %}
  {% set pageImage = metadata.url + metadata.image %}

  <meta name="description" content="{{ pageDescription }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="Openflows">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:image" content="{{ pageImage }}">
  <meta property="og:type" content="{% if currencyType %}article{% else %}website{% endif %}">
  {% if lang == 'zh' %}
  <meta property="og:locale" content="zh_CN">
  <meta property="og:locale:alternate" content="en_US">
  {% else %}
  <meta property="og:locale" content="en_US">
  <meta property="og:locale:alternate" content="zh_CN">
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ pageImage }}">

  <link rel="alternate" type="application/rss+xml" title="Openflows Currency RSS" href="/currency/feed.xml">
  <link rel="alternate" type="application/feed+json" title="Openflows Currency JSON Feed" href="/currency/feed.json">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-F7DCVTHTKE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());

    gtag('config', 'G-F7DCVTHTKE');
  </script>
  <style>
    :root {
      --bg: #f9f8f4;
      --ink: #1b1e1f;
      --muted: #596266;
      --line: #d6d4cb;
      --panel: #f0eee7;
      --accent: #1d5f57;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 2rem 1rem 3rem;
      background: radial-gradient(circle at top, #ffffff 0%, var(--bg) 38%);
      color: var(--ink);
      font-family: "Palatino Linotype", Palatino, "Book Antiqua", serif;
      line-height: 1.6;
    }
    :lang(zh) body, :lang(zh) {
      font-family: "Noto Serif SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Palatino Linotype", serif;
    }
    .wrap { max-width: 46rem; margin: 0 auto; }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--ink);
    }
    .brand-logo {
      display: block;
      width: 64px;
      height: 64px;
      object-fit: contain;
      border-radius: 4px;
    }
    .footer-brand .brand-logo {
      width: 44px;
      height: 44px;
    }
    h1, h2, h3 { line-height: 1.2; letter-spacing: 0.01em; }
    h1 { margin-bottom: 0.5rem; }
    a { color: var(--accent); text-underline-offset: 0.15em; }
    nav { display: flex; gap: 1rem; margin-bottom: 0.7rem; flex-wrap: wrap; }
    nav a { text-decoration: none; border-bottom: 1px solid transparent; }
    nav a:hover { border-color: var(--accent); }
    .lang-switch { margin-left: auto; font-size: 0.9rem; color: var(--muted); }
    hr { border: 0; border-top: 1px solid var(--line); margin: 0.75rem 0 1.25rem; }
    .muted { color: var(--muted); }
    .meta {
      margin: 0.25rem 0 1rem;
      font-size: 0.95rem;
      color: var(--muted);
    }
    .chip {
      display: inline-block;
      padding: 0.08rem 0.45rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      font-size: 0.78rem;
      background: #fff;
      text-transform: capitalize;
      letter-spacing: 0.02em;
    }
    .currency-list {
      list-style: none;
      margin: 0.65rem 0 0;
      padding: 0;
    }
    .currency-list li {
      padding: 0.7rem 0;
      border-top: 1px solid var(--line);
    }
    .currency-list li:last-child { border-bottom: 1px solid var(--line); }
    .item-meta {
      margin-top: 0.2rem;
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .item-abstract {
      margin: 0.35rem 0 0;
      color: var(--muted);
      line-height: 1.45;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-top: 0.75rem;
    }
    .feature-panel {
      border: 1px solid var(--line);
      background: #fcfbf8;
      padding: 0.9rem 1rem;
    }
    .feature-panel h3 {
      margin-top: 0;
      margin-bottom: 0.35rem;
    }
    .feature-list {
      list-style: none;
      margin: 0.5rem 0 0;
      padding: 0;
    }
    .feature-list li {
      padding: 0.55rem 0;
      border-top: 1px solid var(--line);
    }
    .feature-list li:first-child {
      border-top: 0;
      padding-top: 0.2rem;
    }
    @media (min-width: 760px) {
      .feature-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    .mediation-note {
      border: 1px solid var(--line);
      padding: 0.9rem 1rem;
      margin-top: 1.25rem;
      background: var(--panel);
    }
    .connection-note {
      border: 1px solid var(--line);
      padding: 0.9rem 1rem;
      margin-top: 1.25rem;
      background: #f5f4ef;
    }
    .connection-list {
      margin: 0.6rem 0 0;
      padding-left: 1.1rem;
    }
    footer {
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--line);
    }
    .footer-links {
      margin-top: 0.55rem;
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
      font-size: 0.95rem;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <h1>
        {% if lang == 'zh' %}
        <a href="/zh/" class="brand">
        {% else %}
        <a href="/" class="brand">
        {% endif %}
          <img src="/assets/img/openflowslogo.jpg" alt="Openflows logo" class="brand-logo">
          <span>Openflows</span>
        </a>
      </h1>
      <nav>
        {% if lang == 'zh' %}
          <a href="/zh/currency/">流通</a>
          <a href="/about/">关于</a>
          <a href="/contact/">联系</a>
          <a href="{{ page.url | replace('/zh/', '/') }}" class="lang-switch">English</a>
        {% else %}
          <a href="/system/">System</a>
          <a href="/methods/">Methods</a>
          <a href="/currency/">Currency</a>
          <a href="/perspective/">Perspective</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="/zh{{ page.url }}" class="lang-switch">中文</a>
        {% endif %}
      </nav>
      <hr>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      {% if lang == 'zh' %}
      <a href="/zh/" class="brand footer-brand">
      {% else %}
      <a href="/" class="brand footer-brand">
      {% endif %}
        <img src="/assets/img/openflowslogo.jpg" alt="Openflows logo" class="brand-logo">
        <span>Openflows</span>
      </a>
      <div class="footer-links">
        {% if lang == 'zh' %}
          <a href="/about/">关于</a>
          <a href="/contact/">联系</a>
        {% else %}
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        {% endif %}
      </div>
      {% if lang == 'zh' %}
      <p style="margin-top:1rem;font-size:0.85rem;color:var(--muted);">
        本站中文内容由机器翻译生成，仅供参考。如发现翻译问题，请联系 <a href="mailto:openflows@gmail.com">openflows@gmail.com</a>。
      </p>
      {% endif %}
      <div style="margin-top:1.25rem;">
        <a href="https://metaviews.ca" rel="noopener">
          <img src="/assets/img/logowide-cherry.png" alt="Metaviews" style="height:36px;width:auto;display:block;">
        </a>
      </div>
    </footer>
  </div>
</body>
</html>
