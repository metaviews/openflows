<!doctype html>
<html lang="{{ lang or 'en' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Openflows" }}{% if title and title != "Openflows" %} — Openflows{% endif %}</title>

  {% set pageTitle = title or metadata.title %}
  {% set pageDescription = abstract or description or metadata.description %}
  {% set pageUrl = metadata.url + page.url %}
  {% set pageImage = (heroImage or image or metadata.image) | absoluteUrl(metadata.url) %}
  {% set pageLang = lang or 'en' %}
  {% set schemaLang = 'zh-Hans' if pageLang == 'zh' else 'en' %}
  {% set alternateUrl = "" %}
  {% if currencyId %}
    {% set langTarget = collections.allCurrency | currencyCounterpart(currencyId, pageLang) %}
    {% if langTarget %}
      {% set alternateUrl = metadata.url + langTarget.url %}
    {% endif %}
  {% elif blogId %}
    {% set langTarget = collections.allBlog | blogCounterpart(blogId, pageLang) %}
    {% if langTarget %}
      {% set alternateUrl = metadata.url + langTarget.url %}
    {% endif %}
  {% elif page.url == "/" %}
    {% set alternateUrl = metadata.url + "/zh/" %}
  {% elif page.url == "/zh/" %}
    {% set alternateUrl = metadata.url + "/" %}
  {% elif page.url == "/blog/" %}
    {% set alternateUrl = metadata.url + "/zh/blog/" %}
  {% elif page.url == "/zh/blog/" %}
    {% set alternateUrl = metadata.url + "/blog/" %}
  {% elif page.url == "/currency/" or page.url == "/currency/currents/" or page.url == "/currency/circuits/" or page.url == "/currency/practitioners/" %}
    {% set alternateUrl = metadata.url + "/zh" + page.url %}
  {% elif page.url == "/zh/currency/" or page.url == "/zh/currency/currents/" or page.url == "/zh/currency/circuits/" or page.url == "/zh/currency/practitioners/" %}
    {% set alternateUrl = metadata.url + (page.url | replace("/zh", "")) %}
  {% endif %}

  <meta name="description" content="{{ pageDescription }}">
  <meta name="theme-color" content="#090909">
  <link rel="canonical" href="{{ pageUrl }}">
  {% if alternateUrl %}
    {% if pageLang == 'zh' %}
  <link rel="alternate" hreflang="zh-Hans" href="{{ pageUrl }}">
  <link rel="alternate" hreflang="en" href="{{ alternateUrl }}">
  <link rel="alternate" hreflang="x-default" href="{{ alternateUrl }}">
    {% else %}
  <link rel="alternate" hreflang="en" href="{{ pageUrl }}">
  <link rel="alternate" hreflang="zh-Hans" href="{{ alternateUrl }}">
  <link rel="alternate" hreflang="x-default" href="{{ pageUrl }}">
    {% endif %}
  {% endif %}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="manifest" href="/site.webmanifest">

  <!-- Open Graph -->
  <meta property="og:site_name" content="Openflows">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:image" content="{{ pageImage }}">
  <meta property="og:type" content="{% if currencyType or blogId %}article{% else %}website{% endif %}">
  {% if currencyType or blogId %}
  <meta property="article:published_time" content="{{ date | isoDate }}">
    {% if lastReviewed %}
  <meta property="article:modified_time" content="{{ lastReviewed | isoDate }}">
    {% endif %}
    {% if topics %}
      {% for topic in topics %}
  <meta property="article:tag" content="{{ topic }}">
      {% endfor %}
    {% endif %}
  {% endif %}
  {% if lang == 'zh' %}
  <meta property="og:locale" content="zh_CN">
  <meta property="og:locale:alternate" content="en_US">
  {% else %}
  <meta property="og:locale" content="en_US">
  <meta property="og:locale:alternate" content="zh_CN">
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="{% if heroImage or image %}summary_large_image{% else %}summary{% endif %}">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ pageImage }}">

  <link rel="alternate" type="application/rss+xml" title="Openflows Currency RSS" href="/currency/feed.xml">
  <link rel="alternate" type="application/feed+json" title="Openflows Currency JSON Feed" href="/currency/feed.json">
  <link rel="alternate" type="application/rss+xml" title="Openflows Field Notes RSS" href="/blog/feed.xml">
  <link rel="alternate" type="application/feed+json" title="Openflows Field Notes JSON Feed" href="/blog/feed.json">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ metadata.url }}/#organization",
        "name": "Openflows",
        "url": "{{ metadata.url }}/",
        "logo": "{{ pageImage }}"
      },
      {
        "@type": "WebSite",
        "@id": "{{ metadata.url }}/#website",
        "name": "Openflows",
        "url": "{{ metadata.url }}/",
        "description": {{ metadata.description | dump | safe }},
        "publisher": { "@id": "{{ metadata.url }}/#organization" },
        "inLanguage": ["en", "zh-Hans"],
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ metadata.url }}/currency/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "{% if currencyType == 'practitioner' %}ProfilePage{% elif currencyType or blogId %}Article{% else %}WebPage{% endif %}",
        "@id": "{{ pageUrl }}#primary",
        "url": "{{ pageUrl }}",
        "name": {{ pageTitle | dump | safe }},
        "description": {{ pageDescription | dump | safe }},
        "isPartOf": { "@id": "{{ metadata.url }}/#website" },
        "publisher": { "@id": "{{ metadata.url }}/#organization" },
        "inLanguage": "{{ schemaLang }}"{% if currencyType or blogId %},
        "datePublished": "{{ date | isoDate }}"{% if lastReviewed %},
        "dateModified": "{{ lastReviewed | isoDate }}"{% endif %},
        "image": "{{ pageImage }}"{% if humanEditor %},
        "editor": {{ humanEditor | dump | safe }}{% endif %}{% if topics %},
        "keywords": {{ topics | dump | safe }}{% endif %}{% endif %}{% if currencyId %},
        "identifier": {{ currencyId | dump | safe }},
        "genre": {{ currencyType | dump | safe }}{% endif %}{% if blogId %},
        "identifier": {{ blogId | dump | safe }},
        "genre": "longform analysis"{% endif %}{% if currencyType == 'practitioner' %},
        "mainEntity": {
          "@type": "Person",
          "name": {{ pageTitle | dump | safe }}{% if socialProfiles and socialProfiles.length %},
          "sameAs": [{% for profile in socialProfiles %}{{ profile.url | dump | safe }}{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}
        }{% endif %}
      }{% if page.url != "/" %},
      {
        "@type": "BreadcrumbList",
        "@id": "{{ pageUrl }}#breadcrumb",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Openflows",
            "item": "{{ metadata.url }}/"
          }{% if currencyType %},
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Currency",
            "item": "{{ metadata.url }}/currency/"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "{{ currencyType | typeLabel('en') }}",
            "item": "{{ metadata.url }}/currency/{{ currencyType }}{% if currencyType == 'current' %}s{% elif currencyType == 'circuit' %}s{% else %}s{% endif %}/"
          },
          {
            "@type": "ListItem",
            "position": 4,
            "name": {{ pageTitle | dump | safe }},
            "item": "{{ pageUrl }}"
          }{% elif blogId %},
          {
            "@type": "ListItem",
            "position": 2,
            "name": "{% if pageLang == 'zh' %}田野札记{% else %}Field Notes{% endif %}",
            "item": "{{ metadata.url }}{% if pageLang == 'zh' %}/zh/blog/{% else %}/blog/{% endif %}"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ pageTitle | dump | safe }},
            "item": "{{ pageUrl }}"
          }{% else %},
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ pageTitle | dump | safe }},
            "item": "{{ pageUrl }}"
          }{% endif %}
        ]
      }{% endif %}
    ]
  }
  </script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-F7DCVTHTKE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());

    gtag('config', 'G-F7DCVTHTKE');
  </script>
  <style>
    :root {
      --bg: #05070a;
      --surface: #372222;
      --surface-2: #4a2a2a;
      --ink: #f4eee9;
      --muted: #d2c4bd;
      --line: rgba(255, 238, 230, 0.28);
      --panel: #422525;
      --accent: #ff334d;
      --accent-2: #ff8a72;
      --accent-3: #6fe7ff;
      --shadow: 0 18px 56px rgba(0, 0, 0, 0.42);
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    body {
      margin: 0;
      background:
        linear-gradient(120deg, rgba(255, 51, 77, 0.34) 0, rgba(255, 51, 77, 0.13) 19rem, rgba(5, 7, 10, 0) 43rem),
        linear-gradient(245deg, rgba(111, 231, 255, 0.18) 0, rgba(5, 7, 10, 0) 32rem),
        linear-gradient(180deg, #12080b 0, var(--bg) 26rem),
        var(--bg);
      color: var(--ink);
      font-family: Georgia, "Times New Roman", serif;
      line-height: 1.6;
    }
    :lang(zh) body, :lang(zh) {
      font-family: "Noto Serif SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Palatino Linotype", serif;
    }
    .wrap {
      max-width: 78rem;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }
    header.site-header {
      padding: 1.1rem 0 1rem;
      border-bottom: 1px solid var(--line);
      margin-bottom: 1.5rem;
    }
    .header-row {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--ink);
      font-weight: 700;
      letter-spacing: 0;
    }
    .brand-logo {
      display: block;
      width: clamp(220px, 30vw, 360px);
      height: auto;
      object-fit: contain;
      border-radius: 4px;
    }
    .footer-brand .brand-logo {
      width: clamp(190px, 24vw, 280px);
      height: auto;
    }
    h1, h2, h3 {
      line-height: 1.18;
      letter-spacing: 0;
      overflow-wrap: anywhere;
    }
    h1 { margin: 0; font-size: 1.7rem; }
    h2 { margin-top: 2rem; }
    h3 { margin-top: 1.4rem; }
    main {
      max-width: 58rem;
      margin: 0 auto;
    }
    main > p, main > ul, main > ol, main > article, main > h2, main > h3 {
      max-width: 48rem;
    }
    a { color: var(--accent); text-underline-offset: 0.15em; }
    a:hover { color: var(--accent-2); }
    .skip-link {
      position: absolute;
      left: 1rem;
      top: -4rem;
      z-index: 10;
      padding: 0.55rem 0.75rem;
      border-radius: 8px;
      background: var(--accent);
      color: #090909;
      font-family: Arial, "Helvetica Neue", sans-serif;
    }
    .skip-link:focus { top: 1rem; }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    nav {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.35rem;
      flex-wrap: wrap;
      font-family: Arial, "Helvetica Neue", sans-serif;
    }
    nav a {
      color: var(--ink);
      text-decoration: none;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 0.35rem 0.55rem;
      font-size: 0.92rem;
      line-height: 1.2;
    }
    .nav-group {
      position: relative;
      display: inline-flex;
      align-items: center;
    }
    .subnav {
      display: none;
      position: absolute;
      top: calc(100% + 0.25rem);
      right: 0;
      min-width: 9rem;
      padding: 0.35rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: var(--shadow);
      z-index: 3;
    }
    .subnav a {
      display: block;
      white-space: nowrap;
    }
    .nav-group:hover .subnav,
    .nav-group:focus-within .subnav {
      display: block;
    }
    nav a:hover {
      border-color: var(--line);
      background: rgba(255, 75, 67, 0.12);
      color: var(--accent-2);
    }
    .lang-switch {
      border-color: var(--line);
      background: var(--surface);
      color: var(--accent);
    }
    hr { display: none; }
    .muted { color: var(--muted); }
    .meta {
      margin: 0.25rem 0 1rem;
      font-size: 0.95rem;
      color: var(--muted);
    }
    .chip {
      display: inline-block;
      padding: 0.12rem 0.48rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      font-size: 0.78rem;
      background: var(--surface);
      text-transform: capitalize;
      letter-spacing: 0;
      font-family: Arial, "Helvetica Neue", sans-serif;
      line-height: 1.25;
    }
    .chip.alert {
      border-color: rgba(255, 75, 67, 0.42);
      color: var(--accent-2);
      background: rgba(255, 75, 67, 0.12);
    }
    .hero-panel, .section-band, .browser-panel, .entry-shell {
      border: 1px solid var(--line);
      background:
        linear-gradient(145deg, rgba(255, 51, 77, 0.24) 0, rgba(55, 34, 34, 0.98) 30rem),
        rgba(55, 34, 34, 0.98);
      box-shadow: var(--shadow);
      border-radius: 8px;
    }
    .section-band {
      max-width: none;
      padding: 1rem;
      margin: 1.25rem 0 1.75rem;
    }
    .hero-panel {
      max-width: none;
      padding: 1.4rem;
      margin: 0 0 1.5rem;
      display: grid;
      gap: 1.25rem;
      grid-template-columns: 1fr;
    }
    .hero-kicker {
      color: var(--accent-2);
      font-family: Arial, "Helvetica Neue", sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0;
      text-transform: uppercase;
      margin: 0 0 0.45rem;
    }
    .hero-panel h2,
    .hero-panel h1 {
      margin: 0;
      font-size: clamp(2rem, 7vw, 4rem);
      line-height: 1.03;
    }
    .hero-panel p {
      font-size: 1.08rem;
      margin: 0.75rem 0 0;
      max-width: 46rem;
    }
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      align-content: start;
    }
    .stat {
      border: 1px solid var(--line);
      background: linear-gradient(160deg, rgba(255, 51, 77, 0.34), var(--surface-2) 62%);
      border-radius: 8px;
      padding: 0.7rem;
      min-height: 5.3rem;
    }
    .stat strong {
      display: block;
      font-family: Arial, "Helvetica Neue", sans-serif;
      font-size: 1.55rem;
      line-height: 1.1;
    }
    .stat span {
      color: var(--muted);
      font-size: 0.86rem;
    }
    .currency-list {
      list-style: none;
      margin: 0.65rem 0 0;
      padding: 0;
    }
    .currency-list li {
      padding: 0.85rem 0;
      border-top: 1px solid var(--line);
    }
    .currency-list li:last-child { border-bottom: 1px solid var(--line); }
    .currency-list a {
      font-weight: 700;
      overflow-wrap: anywhere;
    }
    .item-meta {
      margin-top: 0.2rem;
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .item-abstract {
      margin: 0.35rem 0 0;
      color: var(--muted);
      line-height: 1.45;
    }
    .grid-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
      gap: 1rem;
      margin: 1rem 0 0;
      max-width: none;
    }
    .hub-card {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255, 51, 77, 0.22), var(--surface) 46%);
      border-radius: 8px;
      padding: 1rem;
      min-height: 11rem;
    }
    .hub-card h3 {
      margin-top: 0;
      margin-bottom: 0.4rem;
    }
    .hub-card p {
      margin-top: 0.4rem;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-top: 0.75rem;
    }
    .feature-panel {
      border: 1px solid var(--line);
      background: var(--surface);
      padding: 0.9rem 1rem;
    }
    .feature-panel h3 {
      margin-top: 0;
      margin-bottom: 0.35rem;
    }
    .feature-list {
      list-style: none;
      margin: 0.5rem 0 0;
      padding: 0;
    }
    .feature-list li {
      padding: 0.55rem 0;
      border-top: 1px solid var(--line);
    }
    .feature-list li:first-child {
      border-top: 0;
      padding-top: 0.2rem;
    }
    @media (min-width: 760px) {
      .feature-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    .mediation-note {
      border: 1px solid var(--line);
      padding: 0.9rem 1rem;
      margin-top: 1.25rem;
      background: var(--panel);
      border-radius: 8px;
    }
    .connection-note {
      border: 1px solid var(--line);
      padding: 0.9rem 1rem;
      margin-top: 1.25rem;
      background: var(--surface);
      border-radius: 8px;
    }
    .connection-list {
      margin: 0.6rem 0 0;
      padding-left: 1.1rem;
    }
    .currency-section {
      margin-top: 1.75rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--line);
    }
    .currency-section:first-of-type {
      border-top: 0;
      padding-top: 0;
      margin-top: 1rem;
    }
    .currency-section-header {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }
    .currency-section-header h2 {
      margin: 0;
    }
    .entry-count {
      font-size: 0.88rem;
    }
    .filter-bar {
      display: grid;
      gap: 0.75rem;
      margin: 0.9rem 0 0.25rem;
    }
    .filter-bar input,
    .filter-bar select {
      width: 100%;
      padding: 0.62rem 0.7rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      font-family: Arial, "Helvetica Neue", sans-serif;
      font-size: 0.95rem;
      color: var(--ink);
      outline: none;
    }
    .filter-bar input:focus,
    .filter-bar select:focus {
      border-color: var(--accent);
    }
    .filter-bar select:disabled,
    .browser-controls select:disabled {
      color: var(--muted);
      background: var(--surface-2);
    }
    .browser-panel {
      max-width: none;
      margin: 1.25rem 0 1.75rem;
      padding: 1rem;
    }
    .browser-panel h2 {
      margin: 0;
    }
    .browser-controls {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .browser-results {
      display: grid;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .browser-result {
      border: 1px solid var(--line);
      background: var(--surface);
      border-radius: 8px;
      padding: 0.85rem;
    }
    .browser-result h3 {
      margin: 0 0 0.35rem;
      font-size: 1.1rem;
    }
    .browser-result p {
      margin: 0.4rem 0;
    }
    .entry-shell {
      max-width: none;
      padding: 1.2rem;
    }
    .blog-entry {
      max-width: 62rem;
      margin: 0 auto;
      padding: clamp(1rem, 3vw, 2rem);
    }
    .blog-header {
      max-width: 48rem;
      margin: 0 auto;
    }
    .blog-header .item-abstract {
      margin-top: 1rem;
      font-size: 1.08rem;
      color: var(--ink);
    }
    .entry-header h2 {
      margin: 0.3rem 0 0.75rem;
      font-size: clamp(2rem, 6vw, 3.4rem);
    }
    .entry-meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
      gap: 0.65rem;
      margin: 1rem 0 1.2rem;
      font-family: Arial, "Helvetica Neue", sans-serif;
    }
    .entry-meta-item {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 0.6rem;
      background: var(--surface);
      min-width: 0;
    }
    .entry-meta-item span {
      display: block;
      color: var(--muted);
      font-size: 0.78rem;
      margin-bottom: 0.15rem;
    }
    .entry-meta-item strong,
    .entry-meta-item a {
      overflow-wrap: anywhere;
    }
    .entry-body {
      max-width: 48rem;
      margin: 0 auto;
      font-size: 1.05rem;
      line-height: 1.74;
    }
    .blog-entry .entry-body p,
    .blog-entry .entry-body ul,
    .blog-entry .entry-body ol,
    .blog-entry .entry-body blockquote {
      margin-top: 1.05rem;
      margin-bottom: 1.05rem;
    }
    .blog-entry .entry-body h2 {
      margin-top: 2.1rem;
      padding-top: 0.2rem;
      font-size: 1.75rem;
    }
    .blog-entry .entry-body h3 {
      margin-top: 1.8rem;
      font-size: 1.28rem;
    }
    .blog-entry .connection-note {
      max-width: 48rem;
      margin-left: auto;
      margin-right: auto;
    }
    .entry-body img,
    main img {
      max-width: 100%;
      height: auto;
    }
    .blog-hero {
      margin: 1.5rem auto 1.2rem;
      max-width: none;
    }
    .blog-hero img {
      display: block;
      width: 100%;
      max-height: 34rem;
      aspect-ratio: 16 / 9;
      object-fit: contain;
      border-radius: 8px;
      border: 1px solid var(--line);
      background: var(--surface-2);
    }
    .blog-list-image img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .blog-hero figcaption {
      max-width: 48rem;
      margin: 0.5rem auto 0;
      color: var(--muted);
      font-family: Arial, "Helvetica Neue", sans-serif;
      font-size: 0.88rem;
    }
    .share-row {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      max-width: 48rem;
      margin: 1.15rem auto 1.75rem;
      padding: 0.7rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: linear-gradient(90deg, rgba(255, 51, 77, 0.24), rgba(55, 34, 34, 0.96));
      font-family: Arial, "Helvetica Neue", sans-serif;
    }
    .share-label {
      margin-right: 0.2rem;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .share-button {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      min-height: 2.25rem;
      padding: 0.35rem 0.68rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--ink);
      text-decoration: none;
      font: inherit;
      font-size: 0.9rem;
      cursor: pointer;
    }
    .share-icon {
      display: inline-grid;
      place-items: center;
      width: 1.2rem;
      height: 1.2rem;
      border: 1px solid var(--line);
      border-radius: 50%;
      color: var(--accent);
      line-height: 1;
    }
    .share-icon svg {
      width: 0.88rem;
      height: 0.88rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .share-button:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(255, 75, 67, 0.12);
    }
    .blog-list li {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .blog-list-image {
      display: block;
      max-width: 16rem;
    }
    pre, code {
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }
    footer {
      margin-top: 2.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--line);
    }
    .footer-links {
      margin-top: 0.55rem;
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
      font-size: 0.95rem;
    }
    @media (min-width: 720px) {
      .hero-panel {
        grid-template-columns: minmax(0, 1.7fr) minmax(16rem, 0.8fr);
        padding: 1.8rem;
      }
      .browser-controls {
        grid-template-columns: minmax(0, 2fr) minmax(10rem, 0.7fr) minmax(10rem, 0.7fr);
      }
      .browser-results {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .blog-list li {
        grid-template-columns: 12rem minmax(0, 1fr);
      }
      .filter-bar {
        grid-template-columns: minmax(0, 1fr) minmax(10rem, 0.4fr);
      }
    }
    @media (max-width: 640px) {
      .wrap { padding-left: 0.75rem; padding-right: 0.75rem; }
      nav { justify-content: flex-start; }
      .stat-grid { grid-template-columns: 1fr; }
      .hero-panel, .entry-shell, .browser-panel { padding: 1rem; }
    }
  </style>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="wrap">
    <header class="site-header">
      <div class="header-row">
        <div class="site-brand">
          {% if lang == 'zh' %}
          <a href="/zh/" class="brand">
          {% else %}
          <a href="/" class="brand">
          {% endif %}
            <img src="/assets/img/openflows.jpg" alt="Openflows" class="brand-logo">
          </a>
        </div>
      <nav>
        {% if lang == 'zh' %}
          <a href="/zh/currency/">流通</a>
          <a href="/zh/blog/">田野札记</a>
          <span class="nav-group">
            <a href="/about/">关于</a>
          </span>
          <a href="/contact/">联系</a>
          {% if currencyId %}
            {% set langTarget = collections.allCurrency | currencyCounterpart(currencyId, lang) %}
            {% if langTarget %}
              <a href="{{ langTarget.url }}" class="lang-switch">English</a>
            {% else %}
              <a href="{{ page.url | replace('/zh/', '/') }}" class="lang-switch">English</a>
            {% endif %}
          {% elif blogId %}
            {% set langTarget = collections.allBlog | blogCounterpart(blogId, lang) %}
            {% if langTarget %}
              <a href="{{ langTarget.url }}" class="lang-switch">English</a>
            {% else %}
              <a href="{{ page.url | replace('/zh/', '/') }}" class="lang-switch">English</a>
            {% endif %}
          {% else %}
            {% if page.url | startsWith('/zh/currency/') %}
              <a href="{{ page.url | replace('/zh/', '/') }}" class="lang-switch">English</a>
            {% elif page.url | startsWith('/zh/blog/') %}
              <a href="{{ page.url | replace('/zh/', '/') }}" class="lang-switch">English</a>
            {% else %}
              <a href="/" class="lang-switch">English</a>
            {% endif %}
          {% endif %}
        {% else %}
          <a href="/currency/">Currency</a>
          <a href="/blog/">Field Notes</a>
          <a href="/perspective/">Perspective</a>
          <span class="nav-group">
            <a href="/about/">About</a>
            <span class="subnav">
              <a href="/system/">System</a>
              <a href="/methods/">Methods</a>
            </span>
          </span>
          <a href="/contact/">Contact</a>
          {% if currencyId %}
            {% set langTarget = collections.allCurrency | currencyCounterpart(currencyId, lang) %}
            {% if langTarget %}
              <a href="{{ langTarget.url }}" class="lang-switch">中文</a>
            {% else %}
              <a href="/zh{{ page.url }}" class="lang-switch">中文</a>
            {% endif %}
          {% elif blogId %}
            {% set langTarget = collections.allBlog | blogCounterpart(blogId, lang) %}
            {% if langTarget %}
              <a href="{{ langTarget.url }}" class="lang-switch">中文</a>
            {% else %}
              <a href="/zh{{ page.url }}" class="lang-switch">中文</a>
            {% endif %}
          {% else %}
            {% if page.url == "/" %}
              <a href="/zh/" class="lang-switch">中文</a>
            {% elif page.url | startsWith('/currency/') %}
              <a href="/zh{{ page.url }}" class="lang-switch">中文</a>
            {% elif page.url | startsWith('/blog/') %}
              <a href="/zh{{ page.url }}" class="lang-switch">中文</a>
            {% else %}
              <a href="/zh/" class="lang-switch">中文</a>
            {% endif %}
          {% endif %}
        {% endif %}
      </nav>
      </div>
      <hr>
    </header>
    <main id="main">
      {% if title %}<h1 class="sr-only">{{ title }}</h1>{% endif %}
      {{ content | safe }}
    </main>
    <footer>
      {% if lang == 'zh' %}
      <a href="/zh/" class="brand footer-brand">
      {% else %}
      <a href="/" class="brand footer-brand">
      {% endif %}
        <img src="/assets/img/openflows.jpg" alt="Openflows" class="brand-logo">
      </a>
      <div class="footer-links">
        {% if lang == 'zh' %}
          <a href="/about/">关于</a>
          <a href="/contact/">联系</a>
        {% else %}
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        {% endif %}
      </div>
      {% if lang == 'zh' %}
      <p style="margin-top:1rem;font-size:0.85rem;color:var(--muted);">
        本站中文内容由机器翻译生成，仅供参考。如发现翻译问题，请联系 <a href="mailto:openflows@gmail.com">openflows@gmail.com</a>。
      </p>
      {% endif %}
      <div style="margin-top:1.25rem;">
        <a href="https://metaviews.ca" rel="noopener">
          <img src="/assets/img/logowide-cherry.png" alt="Metaviews" style="height:36px;width:auto;display:block;">
        </a>
      </div>
    </footer>
  </div>
</body>
</html>
