        <div class="item-meta">
          <span class="muted">{{ item.date | readableDate }}</span>
        </div>
      </li>
      {% endif %}
    {% endfor %}
  </ul>
  <p><a href="/currency/circuits/">View all circuits</a></p>
</section>

