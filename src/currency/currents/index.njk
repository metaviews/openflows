title: Currents
permalink: /currency/currents/
---
<p>Directional movement signals captured as entries. Currents preserve sensitivity to change and resist premature certainty.</p>

<div class="filter-bar">
  <input type="text" id="entry-filter" placeholder="Filter by title or description…" autocomplete="off">
</div>

{% set items = collections.currents %}
{% include "currency-list.njk" %}

<script>
  const input = document.getElementById('entry-filter');
  const items = document.querySelectorAll('.currency-list li');
  input.addEventListener('input', function() {
    const q = this.value.toLowerCase();
    items.forEach(function(li) {
      li.style.display = li.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
</script>
