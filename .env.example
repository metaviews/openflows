OPENROUTER_API_KEY=your_key_here
# Default model — change freely. See openrouter.ai/models
OPENROUTER_MODEL=your_model_here
# Fallback model used when primary hits a rate limit (429). Optional.
FALLBACK_OPENROUTER_MODEL=your_fallback_model_here

# Intake sources — all optional, omit to skip that source
GITHUB_TOKEN=your_github_pat_here
BRAVE_API_KEY=your_brave_key_here
# Twitter: Bearer token from developer.twitter.com/en/portal/dashboard
# Basic tier or above required for tweet search
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Server (Cycle 10+)
PORT=3000
# Path to SQLite database file. Defaults to data/openflows.db in the repo root.
DB_PATH=
# Git identity for automated commits (promotion, seen.json, digests)
GIT_USER_NAME=Peng (Openflows Agent)
GIT_USER_EMAIL=peng@openflows.org
