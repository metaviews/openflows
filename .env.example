OPENROUTER_API_KEY=your_key_here
# Default model — change freely. See openrouter.ai/models
OPENROUTER_MODEL=your_model_here
# Fallback model used when primary hits a rate limit (429). Optional.
FALLBACK_OPENROUTER_MODEL=your_fallback_model_here

# Intake sources — all optional, omit to skip that source
GITHUB_TOKEN=your_github_pat_here
BRAVE_API_KEY=your_brave_key_here
# Mastodon: optional; public search is attempted first, but some instances require read/search auth
MASTODON_ACCESS_TOKEN=

# X/Twitter via XActions (Cycle 14): optional read-only session configuration.
# XActions is powerful automation software; Openflows only calls read/scrape paths.
XACTIONS_AUTH_TOKEN=
XACTIONS_USER_DATA_DIR=
XACTIONS_HEADLESS=true

# Discord bot (optional — omit DISCORD_BOT_TOKEN to disable)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=           # Server ID for slash command registration
DISCORD_CHANNEL_ID=         # Channel ID for automated notifications (intake, perspective)
DISCORD_AUTHORIZED_USERS=   # Comma-separated Discord user IDs allowed to confirm write tools / run triggers

# Server (Cycle 10+)
PORT=3000
# Path to SQLite database file. Defaults to data/openflows.db in the repo root.
DB_PATH=
# Git identity for automated commits (promotion, seen.json, digests)
GIT_USER_NAME=Peng (Openflows Agent)
GIT_USER_EMAIL=peng@openflows.org
