{% extends "base.njk" %}
{% block title %}Knowledge Base{% endblock %}
{% macro sortHeader(key, label) %}
  {% set nextDir = 'asc' %}
  {% if sort == key and sortDir == 'asc' %}
    {% set nextDir = 'desc' %}
  {% endif %}
  <a class="sort-link{% if sort == key %} sort-active{% endif %}"
     href="/entries?sort={{ key }}&dir={{ nextDir }}{% if filterType %}&type={{ filterType }}{% endif %}{% if filterLang %}&lang={{ filterLang }}{% endif %}">
    {{ label }}
    {% if sort == key %}<span class="sort-arrow">{% if sortDir == 'asc' %}↑{% else %}↓{% endif %}</span>{% endif %}
  </a>
{% endmacro %}

{% block content %}
<div class="page-container">
  <div class="page-header">
    <span class="page-title">
      Knowledge Base
      <span class="muted">({{ entries | length }}{% if entries | length != total %} of {{ total }}{% endif %} entries)</span>
    </span>
    <div class="filter-bar">
      <span>Type:</span>
      <select id="filter-type" onchange="applyFilters()">
        <option value="" {% if not filterType %}selected{% endif %}>all</option>
        <option value="current"      {% if filterType == 'current' %}selected{% endif %}>current</option>
        <option value="circuit"      {% if filterType == 'circuit' %}selected{% endif %}>circuit</option>
        <option value="practitioner" {% if filterType == 'practitioner' %}selected{% endif %}>practitioner</option>
      </select>
      <span>Lang:</span>
      <select id="filter-lang" onchange="applyFilters()">
        <option value="" {% if not filterLang %}selected{% endif %}>all</option>
        <option value="en" {% if filterLang == 'en' %}selected{% endif %}>en</option>
        <option value="zh" {% if filterLang == 'zh' %}selected{% endif %}>zh</option>
      </select>
    </div>
  </div>

  <table class="entries-table">
    <thead>
      <tr>
        <th>{{ sortHeader('id', 'ID') }}</th>
        <th>{{ sortHeader('type', 'Type') }}</th>
        <th>{{ sortHeader('lang', 'Lang') }}</th>
        <th>{{ sortHeader('title', 'Title') }}</th>
        <th>{{ sortHeader('date', 'Date') }}</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for entry in entries %}
      <tr>
        <td class="id-cell">
          <a href="/entries/{{ entry.currencyId }}?lang={{ entry.lang }}">{{ entry.currencyId }}</a>
        </td>
        <td><span class="badge badge-{{ entry.currencyType }}">{{ entry.currencyType }}</span></td>
        <td><span class="badge badge-{{ entry.lang }}">{{ entry.lang }}</span></td>
        <td class="title-cell">{{ entry.title }}</td>
        <td class="run-time">{{ entry.date | truncate(10, true, '') if entry.date }}</td>
        <td class="actions-cell">
          {% if entry.lang === 'en' and not translatedIds[entry.currencyId] %}
          <button class="btn btn-sm"
                  id="translate-{{ entry.currencyId }}"
                  onclick="translateEntry('{{ entry.currencyId }}', this)">Translate</button>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<script>
function applyFilters() {
  const type = document.getElementById('filter-type').value
  const lang = document.getElementById('filter-lang').value
  const params = new URLSearchParams()
  if (type) params.set('type', type)
  if (lang) params.set('lang', lang)
  params.set('sort', '{{ sort }}')
  params.set('dir', '{{ sortDir }}')
  window.location.href = '/entries' + (params.toString() ? '?' + params.toString() : '')
}

async function translateEntry(id, btn) {
  btn.disabled = true
  btn.textContent = 'queued…'
  try {
    const resp = await fetch('/api/trigger/translate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ args: ['--id', id] })
    })
    const data = await resp.json().catch(() => ({}))
    if (!resp.ok) {
      btn.textContent = 'error'
      btn.disabled = false
      alert(data.error || 'Translation failed')
    } else {
      btn.textContent = 'running…'
      if (data.runId && typeof openLog === 'function') openLog(data.runId, 'translate')
      if (typeof refreshDashboardPanels === 'function') refreshDashboardPanels()
    }
  } catch (err) {
    btn.textContent = 'error'
    btn.disabled = false
    alert('Error: ' + err.message)
  }
}
</script>
{% endblock %}
