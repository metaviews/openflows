<tr id="draft-{{ draft.id }}-{{ draft.lang }}"
    class="{% if draft.status == 'promoted' %}draft-promoted{% elif draft.status == 'rejected' %}draft-rejected{% endif %}">
  <td class="id-cell"><a href="/queue/{{ draft.id }}/edit?lang={{ draft.lang }}">{{ draft.id }}</a></td>
  <td>
    <span class="badge badge-{{ draft.type or 'unknown' }}">{{ draft.type or '?' }}</span>
  </td>
  <td>
    <span class="badge badge-{{ draft.lang }}">{{ draft.lang }}</span>
  </td>
  <td class="title-cell" title="{{ draft.title }}">{{ draft.title or '(untitled)' }}</td>
  <td class="run-time">
    {{ draft.created_at | truncate(10, true, '') if draft.created_at }}
    {% if draft.isNew %}<span class="badge badge-new">new</span>{% endif %}
    {% if draft.isStale %}<span class="badge badge-stale">stale</span>{% endif %}
  </td>
  <td class="actions-cell">
    {% if draft.status == 'pending' %}
    <a href="/queue/{{ draft.id }}/edit?lang={{ draft.lang }}" class="btn btn-sm">Edit</a>
    <button class="btn btn-sm" onclick="previewDraft('{{ draft.id }}', '{{ draft.lang }}')">Preview</button>
    <button class="btn btn-sm btn-promote"
            onclick="confirmQueuePromote('{{ draft.id }}', '{{ draft.lang }}')">P</button>
    <button class="btn btn-sm btn-reject"
            onclick="confirmQueueReject('{{ draft.id }}', '{{ draft.lang }}')">R</button>
    {% else %}
    <span class="badge badge-{{ draft.status }}">{{ draft.status }}</span>
    {% endif %}
  </td>
</tr>
