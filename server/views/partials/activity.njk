<div id="activity-panel" class="panel"
     hx-get="/api/runs?limit=10"
     hx-trigger="every 15s, refresh from:body"
     hx-target="#activity-panel"
     hx-swap="outerHTML">
  <div class="panel-header">
    <span class="panel-title">Activity</span>
    <button class="btn btn-sm"
            hx-get="/api/runs?limit=10"
            hx-target="#activity-panel"
            hx-swap="outerHTML">Refresh</button>
  </div>
  <div class="panel-body" style="padding: 0.5rem 1rem;">
    {% if runs and runs.length %}
    <ul class="run-list">
      {% for run in runs %}
      <li class="run-item run-item-clickable" onclick="openLog({{ run.id }}, '{{ run.type }}')" title="View log">
        <span class="run-type">{{ run.type }}</span>
        <span class="badge badge-{{ run.status }}">{{ run.status }}</span>
        <span class="run-summary" title="{{ run.summary }}">{{ run.summary or '—' }}</span>
        <span class="run-time">{{ run.started_at | truncate(16, true, '') }} <span class="run-log-hint">log</span></span>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="empty-state">No runs yet.</p>
    {% endif %}
  </div>
</div>
