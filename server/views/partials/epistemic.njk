<div class="panel col-full">
  <div class="panel-header">
    <span class="panel-title">Epistemic Window — Ask Peng</span>
    <span class="muted" style="font-size:0.7rem">Knowledge manifest · OpenRouter · streaming</span>
  </div>
  <div class="panel-body">
    <div class="ask-form">
      <input id="peng-query"
             type="text"
             placeholder="Ask Peng about the ecosystem… (Enter to send)"
             autocomplete="off"
             spellcheck="false">
      <button id="peng-ask-btn" class="btn btn-primary" onclick="askPeng()">Ask</button>
    </div>
    <div id="peng-response" class="muted" style="font-style:italic">
      Peng is ready. Ask about patterns, entries, connections, or what the ecosystem is doing.
    </div>
  </div>
</div>
