<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Peng Dashboard{% endblock %} — Openflows</title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.3" crossorigin="anonymous" defer></script>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="brand">鵬 Peng <small>/ Openflows Dashboard</small></a>
      <nav>
        <a href="/api/status">Status API</a>
        <a href="https://openflows.org" target="_blank" rel="noopener">Site ↗</a>
        <a href="https://github.com" target="_blank" rel="noopener">GitHub ↗</a>
      </nav>
    </div>
  </header>

  {% block content %}{% endblock %}

  <script>
    // ── Epistemic query streaming ─────────────────────────────────────────────
    async function askPeng() {
      const input = document.getElementById('peng-query')
      const question = input.value.trim()
      if (!question) return

      const output = document.getElementById('peng-response')
      const btn = document.getElementById('peng-ask-btn')

      output.textContent = ''
      output.classList.add('thinking')
      btn.disabled = true

      // Build message history from any prior exchange shown in the DOM.
      const messages = []

      try {
        const resp = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question, messages })
        })

        if (!resp.ok) {
          output.textContent = 'Error: ' + resp.statusText
          return
        }

        output.classList.remove('thinking')
        const reader = resp.body.getReader()
        const decoder = new TextDecoder()
        let buffer = ''

        while (true) {
          const { done, value } = await reader.read()
          if (done) break
          buffer += decoder.decode(value, { stream: true })
          const lines = buffer.split('\n')
          buffer = lines.pop()
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue
            const data = line.slice(6).trim()
            if (data === '[DONE]') return
            try {
              const parsed = JSON.parse(data)
              if (parsed.text) output.textContent += parsed.text
              if (parsed.error) { output.textContent = 'Error: ' + parsed.error; return }
            } catch {}
          }
        }
      } catch (err) {
        output.textContent = 'Error: ' + err.message
      } finally {
        btn.disabled = false
        output.classList.remove('thinking')
      }
    }

    // Allow Enter to submit (Shift+Enter for newline if we add textarea later).
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('peng-query')
      if (input) {
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); askPeng() }
        })
      }
    })

    // ── Trigger buttons ───────────────────────────────────────────────────────
    async function trigger(type) {
      const btn = document.getElementById('trigger-' + type)
      if (btn) btn.disabled = true
      try {
        const resp = await fetch('/api/trigger/' + type, { method: 'POST' })
        const data = await resp.json()
        if (!resp.ok) alert(data.error || 'Trigger failed')
      } catch (err) {
        alert('Trigger error: ' + err.message)
      }
      // Refresh the activity panel after a short delay.
      setTimeout(() => {
        const panel = document.getElementById('activity-panel')
        if (panel) htmx.trigger(panel, 'refresh')
        if (btn) btn.disabled = false
      }, 1500)
    }
  </script>
</body>
</html>
