<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Peng Dashboard{% endblock %} — Openflows</title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.3" crossorigin="anonymous" defer></script>
  <script src="/vendor/marked/marked.umd.js"></script>
  <script src="/vendor/dompurify/purify.min.js"></script>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="brand">鵬 Peng <small>/ Openflows Dashboard</small></a>
      <nav>
        <a href="/">Dashboard</a>
        <a href="/entries">Knowledge Base</a>
        <a href="https://openflows.org" target="_blank" rel="noopener">Site ↗</a>
        <a href="https://github.com/metaviews/openflows" target="_blank" rel="noopener">GitHub ↗</a>
      </nav>
    </div>
  </header>

  {% block content %}{% endblock %}

  <script>
    // ── Epistemic conversation ────────────────────────────────────────────────
    let conversationHistory = []

    function appendMessage(role, text, id) {
      const container = document.getElementById('conversation')
      if (!container) return null
      const div = document.createElement('div')
      div.className = 'msg msg-' + role
      if (id) div.id = id
      div.textContent = text
      container.appendChild(div)
      container.scrollTop = container.scrollHeight
      return div
    }

    function renderPengMarkdown(el, markdown) {
      if (!el) return
      const raw = markdown || ''
      if (!window.marked || !window.DOMPurify) {
        el.textContent = raw
        return
      }

      const html = window.marked.parse(raw, {
        async: false,
        breaks: true,
        gfm: true,
      })
      el.innerHTML = window.DOMPurify.sanitize(html, { USE_PROFILES: { html: true } })
      el.classList.add('msg-rendered')
      el.querySelectorAll('a').forEach(link => {
        link.setAttribute('target', '_blank')
        link.setAttribute('rel', 'noopener noreferrer')
      })
      enhanceRenderedMarkdown(el)
      linkCurrencyIds(el)
    }

    function enhanceRenderedMarkdown(root) {
      root.querySelectorAll('pre').forEach(pre => {
        if (pre.querySelector('.copy-code')) return
        const btn = document.createElement('button')
        btn.className = 'btn btn-sm copy-code'
        btn.textContent = 'Copy'
        btn.onclick = () => navigator.clipboard?.writeText(pre.innerText.replace(/^Copy\s*/, ''))
        pre.prepend(btn)
      })
    }

    function linkCurrencyIds(root) {
      const ids = new Set((window.OPENFLOWS_IDS || []))
      if (!ids.size) return
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT)
      const nodes = []
      while (walker.nextNode()) nodes.push(walker.currentNode)
      for (const node of nodes) {
        const words = node.nodeValue.split(/(\b[a-z0-9]+(?:-[a-z0-9]+)+\b)/g)
        if (!words.some(word => ids.has(word))) continue
        const frag = document.createDocumentFragment()
        for (const word of words) {
          if (ids.has(word)) {
            const a = document.createElement('a')
            a.href = '/entries/' + word + '?lang=en'
            a.textContent = word
            frag.appendChild(a)
          } else {
            frag.appendChild(document.createTextNode(word))
          }
        }
        node.parentNode.replaceChild(frag, node)
      }
    }

    function clearConversation() {
      conversationHistory = []
      const container = document.getElementById('conversation')
      if (container) container.innerHTML = ''
    }

    async function loadConversation(id) {
      const resp = await fetch('/api/conversations/' + id)
      const data = await resp.json()
      if (!resp.ok) return alert(data.error || 'Conversation not found')
      conversationHistory = data.conversation.messages || []
      const container = document.getElementById('conversation')
      if (!container) return
      container.innerHTML = ''
      for (const message of conversationHistory) {
        const el = appendMessage(message.role === 'assistant' ? 'peng' : 'user', message.content || '')
        if (message.role === 'assistant') renderPengMarkdown(el, message.content || '')
      }
    }

    async function askPeng() {
      const input = document.getElementById('peng-query')
      const question = input.value.trim()
      if (!question) return

      const btn = document.getElementById('peng-ask-btn')
      input.value = ''
      btn.disabled = true

      appendMessage('user', question)
      const responseEl = appendMessage('peng', '…', 'peng-streaming')
      responseEl.classList.add('thinking')

      // Snapshot history before this turn, then push user message.
      const priorHistory = [...conversationHistory]
      conversationHistory.push({ role: 'user', content: question })

      let fullText = ''
      let toolSummaries = []

      try {
        const resp = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question, messages: priorHistory })
        })

        if (!resp.ok) {
          responseEl.textContent = 'Error: ' + resp.statusText
          responseEl.classList.remove('thinking')
          conversationHistory.pop()
          btn.disabled = false
          return
        }

        responseEl.textContent = ''
        responseEl.classList.remove('thinking')

        const reader = resp.body.getReader()
        const decoder = new TextDecoder()
        let buffer = ''

        while (true) {
          const { done, value } = await reader.read()
          if (done) break
          buffer += decoder.decode(value, { stream: true })
          const lines = buffer.split('\n')
          buffer = lines.pop()
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue
            const data = line.slice(6).trim()
            if (data === '[DONE]') {
              responseEl.removeAttribute('id')
              renderPengMarkdown(responseEl, fullText)
              appendToolSummary(responseEl, toolSummaries)
              conversationHistory.push({ role: 'assistant', content: fullText })
              btn.disabled = false
              return
            }
            try {
              const parsed = JSON.parse(data)
              if (parsed.text) {
                fullText += parsed.text
                responseEl.textContent = fullText
                const container = document.getElementById('conversation')
                if (container) container.scrollTop = container.scrollHeight
              }
              if (parsed.tools) {
                toolSummaries = parsed.tools
              }
              if (parsed.confirmation) {
                renderConfirmation(responseEl, parsed.confirmation)
                btn.disabled = false
                return
              }
              if (parsed.error) {
                responseEl.textContent = 'Error: ' + parsed.error
                responseEl.classList.add('thinking')
                conversationHistory.pop()
                btn.disabled = false
                return
              }
            } catch {}
          }
        }
      } catch (err) {
        responseEl.textContent = 'Error: ' + err.message
        responseEl.classList.add('thinking')
        conversationHistory.pop()
      }

      responseEl.removeAttribute('id')
      if (fullText) {
        renderPengMarkdown(responseEl, fullText)
        appendToolSummary(responseEl, toolSummaries)
        conversationHistory.push({ role: 'assistant', content: fullText })
      }
      btn.disabled = false
    }

    function renderConfirmation(responseEl, confirmation) {
      responseEl.removeAttribute('id')
      responseEl.classList.remove('thinking')
      responseEl.classList.remove('msg-rendered')
      responseEl.textContent = ''
      if (confirmation.runId) openLog(confirmation.runId, 'peng-tool')
      refreshDashboardPanels()
      const tools = confirmation.tools || []
      const summary = tools.map(tool => {
        const details = [tool.id, tool.lang, tool.type, tool.status].filter(Boolean).join(' / ')
        const suffix = details ? ' - ' + details : ''
        const content = tool.contentLength ? ` (${tool.contentLength} chars)` : ''
        return `${tool.name}${suffix}${content}`
      }).join('\n')

      const text = document.createElement('div')
      text.textContent = 'Peng wants confirmation before running:'
      responseEl.appendChild(text)

      const pre = document.createElement('pre')
      pre.textContent = summary || 'write action'
      responseEl.appendChild(pre)

      const actions = document.createElement('div')
      actions.style.display = 'flex'
      actions.style.gap = '0.5rem'
      actions.style.marginTop = '0.5rem'

      const confirmBtn = document.createElement('button')
      confirmBtn.className = 'btn btn-primary btn-sm'
      confirmBtn.textContent = 'Confirm'
      confirmBtn.onclick = () => confirmPengTool(confirmation.token, responseEl, confirmBtn, cancelBtn)

      const cancelBtn = document.createElement('button')
      cancelBtn.className = 'btn btn-sm'
      cancelBtn.textContent = 'Cancel'
      cancelBtn.onclick = () => {
        if (confirmation.token) {
          fetch('/api/ask/confirmation/' + encodeURIComponent(confirmation.token) + '/cancel', { method: 'POST' })
            .then(() => refreshDashboardPanels())
            .catch(() => {})
        }
        responseEl.textContent = 'Canceled before running the proposed tool call.'
        conversationHistory.push({ role: 'assistant', content: responseEl.textContent })
      }

      actions.appendChild(confirmBtn)
      actions.appendChild(cancelBtn)
      responseEl.appendChild(actions)
    }

    async function confirmPengTool(token, responseEl, confirmBtn, cancelBtn) {
      const btn = document.getElementById('peng-ask-btn')
      if (btn) btn.disabled = true
      confirmBtn.disabled = true
      cancelBtn.disabled = true
      responseEl.textContent = 'Confirmed. Running tool call...'
      responseEl.classList.add('thinking')

      let fullText = ''
      let toolSummaries = []
      try {
        const resp = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: conversationHistory, confirmation: { token } })
        })

        if (!resp.ok) {
          responseEl.textContent = 'Error: ' + resp.statusText
          responseEl.classList.remove('thinking')
          if (btn) btn.disabled = false
          return
        }

        responseEl.textContent = ''
        responseEl.classList.remove('thinking')

        const reader = resp.body.getReader()
        const decoder = new TextDecoder()
        let buffer = ''

        while (true) {
          const { done, value } = await reader.read()
          if (done) break
          buffer += decoder.decode(value, { stream: true })
          const lines = buffer.split('\n')
          buffer = lines.pop()
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue
            const data = line.slice(6).trim()
            if (data === '[DONE]') {
              if (fullText) {
                renderPengMarkdown(responseEl, fullText)
                appendToolSummary(responseEl, toolSummaries)
                conversationHistory.push({ role: 'assistant', content: fullText })
              }
              refreshDashboardPanels()
              if (btn) btn.disabled = false
              return
            }
            try {
              const parsed = JSON.parse(data)
              if (parsed.text) {
                fullText += parsed.text
                responseEl.textContent = fullText
                const container = document.getElementById('conversation')
                if (container) container.scrollTop = container.scrollHeight
              }
              if (parsed.tools) {
                toolSummaries = parsed.tools
              }
              if (parsed.confirmation) {
                renderConfirmation(responseEl, parsed.confirmation)
                if (btn) btn.disabled = false
                return
              }
              if (parsed.error) {
                responseEl.textContent = 'Error: ' + parsed.error
                responseEl.classList.add('thinking')
                if (btn) btn.disabled = false
                return
              }
            } catch {}
          }
        }
      } catch (err) {
        responseEl.textContent = 'Error: ' + err.message
        responseEl.classList.add('thinking')
      }

      if (fullText) {
        renderPengMarkdown(responseEl, fullText)
        appendToolSummary(responseEl, toolSummaries)
        conversationHistory.push({ role: 'assistant', content: fullText })
      }
      refreshDashboardPanels()
      if (btn) btn.disabled = false
    }

    function refreshDashboardPanels() {
      if (!window.htmx) return
      const activity = document.getElementById('activity-panel')
      const queueState = document.getElementById('queue-state-panel')
      const queue = document.getElementById('queue-panel')
      const timeline = document.getElementById('timeline-panel')
      const conversations = document.getElementById('conversations-panel')
      if (activity) htmx.ajax('GET', '/api/runs', { target: '#activity-panel', swap: 'outerHTML' })
      if (queueState) htmx.ajax('GET', '/api/queue/state', { target: '#queue-state-panel', swap: 'outerHTML' })
      if (queue) htmx.ajax('GET', '/api/queue', { target: '#queue-panel', swap: 'outerHTML' })
      if (timeline) htmx.ajax('GET', '/api/timeline', { target: '#timeline-panel', swap: 'outerHTML' })
      if (conversations) htmx.ajax('GET', '/api/conversations', { target: '#conversations-panel', swap: 'outerHTML' })
    }

    function appendToolSummary(responseEl, tools) {
      if (!tools || !tools.length) return
      const details = document.createElement('details')
      details.className = 'tool-summary'
      const summary = document.createElement('summary')
      summary.textContent = `Tools used (${tools.length})`
      details.appendChild(summary)
      const list = document.createElement('ul')
      for (const tool of tools) {
        const li = document.createElement('li')
        li.textContent = [tool.name, tool.id, tool.lang].filter(Boolean).join(' / ')
        list.appendChild(li)
      }
      details.appendChild(list)
      responseEl.appendChild(details)
    }

    async function previewDraft(id, lang) {
      const panel = document.getElementById('draft-preview')
      if (!panel) return
      panel.style.display = 'block'
      panel.innerHTML = '<div class="panel-header"><span class="panel-title">Draft Preview</span></div><div class="panel-body">Loading...</div>'
      const resp = await fetch('/api/queue/' + encodeURIComponent(id) + '/preview?lang=' + encodeURIComponent(lang))
      const data = await resp.json()
      if (!resp.ok) {
        panel.innerHTML = '<div class="panel-header"><span class="panel-title">Draft Preview</span></div><div class="panel-body">Error: ' + (data.error || resp.statusText) + '</div>'
        return
      }
      const body = document.createElement('div')
      body.className = 'panel-body'
      const header = document.createElement('div')
      header.innerHTML = `<strong>${data.draft.title || data.draft.id}</strong> <span class="badge badge-${data.draft.lang}">${data.draft.lang}</span> <span class="badge badge-${data.draft.type || 'unknown'}">${data.draft.type || '?'}</span>`
      body.appendChild(header)
      body.appendChild(renderValidationBlock(data.validation))
      const preview = document.createElement('div')
      preview.className = 'preview-body msg-rendered'
      renderMarkdownInto(preview, data.body || '')
      body.appendChild(preview)
      panel.innerHTML = '<div class="panel-header"><span class="panel-title">Draft Preview</span><button class="btn btn-sm" onclick="document.getElementById(\\'draft-preview\\').style.display=\\'none\\'">Close</button></div>'
      panel.appendChild(body)
    }

    async function confirmQueuePromote(id, lang) {
      let validationText = 'Validation state: unavailable'
      try {
        const resp = await fetch('/api/queue/' + encodeURIComponent(id) + '/preview?lang=' + encodeURIComponent(lang))
        const data = await resp.json()
        if (resp.ok && data.validation) {
          validationText = data.validation.ok
            ? 'Validation state: clean'
            : `Validation state: ${data.validation.counts.error} error(s), ${data.validation.counts.warning} warning(s)`
        }
      } catch {}

      confirmAction({
        title: 'Promote Draft',
        body: [
          `Action: promote_draft`,
          `Affected: ${id} (${lang})`,
          `Writes src/: yes`,
          `Commits/pushes: yes`,
          validationText,
        ].join('\n'),
        confirmText: 'Promote',
        onConfirm: async () => {
          const resp = await fetch('/api/queue/' + encodeURIComponent(id) + '/promote?lang=' + encodeURIComponent(lang), { method: 'POST' })
          const data = await resp.json().catch(() => ({}))
          if (!resp.ok) return alert(data.error || 'Promote failed')
          refreshDashboardPanels()
        }
      })
    }

    function confirmQueueReject(id, lang) {
      confirmAction({
        title: 'Reject Draft',
        body: [
          `Action: reject_draft`,
          `Affected: ${id} (${lang})`,
          `Writes src/: no`,
          `Commits/pushes: no`,
          `Result: marks the draft rejected in the queue`,
        ].join('\n'),
        confirmText: 'Reject',
        onConfirm: async () => {
          const resp = await fetch('/api/queue/' + encodeURIComponent(id) + '/reject?lang=' + encodeURIComponent(lang), { method: 'POST' })
          const data = await resp.json().catch(() => ({}))
          if (!resp.ok) return alert(data.error || 'Reject failed')
          refreshDashboardPanels()
        }
      })
    }

    function renderMarkdownInto(el, markdown) {
      if (window.marked && window.DOMPurify) {
        el.innerHTML = window.DOMPurify.sanitize(window.marked.parse(markdown || '', { breaks: true, gfm: true }), { USE_PROFILES: { html: true } })
        enhanceRenderedMarkdown(el)
      } else {
        el.textContent = markdown || ''
      }
    }

    function renderValidationBlock(validation) {
      const box = document.createElement('div')
      box.className = 'validation-box ' + (validation.ok ? 'validation-ok' : 'validation-error')
      const title = document.createElement('strong')
      title.textContent = validation.ok ? 'Validation passed' : `Validation issues: ${validation.counts.error} error(s), ${validation.counts.warning} warning(s)`
      box.appendChild(title)
      if (validation.issues?.length) {
        const list = document.createElement('ul')
        for (const issue of validation.issues) {
          const li = document.createElement('li')
          li.textContent = `${issue.severity}: ${issue.field} - ${issue.message}`
          list.appendChild(li)
        }
        box.appendChild(list)
      }
      return box
    }

    function confirmAction({ title, body, confirmText = 'Confirm', onConfirm }) {
      const existing = document.getElementById('confirm-overlay')
      if (existing) existing.remove()
      const overlay = document.createElement('div')
      overlay.id = 'confirm-overlay'
      overlay.className = 'confirm-overlay'
      overlay.innerHTML = `
        <div class="confirm-modal">
          <div class="panel-header"><span class="panel-title">${title}</span></div>
          <div class="panel-body"><div class="confirm-body"></div>
            <div class="edit-actions" style="margin-top:1rem;margin-bottom:0">
              <button class="btn btn-primary" id="confirm-action-btn">${confirmText}</button>
              <button class="btn" id="confirm-cancel-btn">Cancel</button>
            </div>
          </div>
        </div>`
      overlay.querySelector('.confirm-body').textContent = body
      document.body.appendChild(overlay)
      overlay.querySelector('#confirm-cancel-btn').onclick = () => overlay.remove()
      overlay.querySelector('#confirm-action-btn').onclick = async () => {
        overlay.remove()
        await onConfirm()
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('peng-query')
      if (input) {
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); askPeng() }
        })
      }
    })

    // ── Trigger buttons ───────────────────────────────────────────────────────
    async function trigger(type) {
      const btn = document.getElementById('trigger-' + type)
      if (btn) btn.disabled = true
      try {
        const resp = await fetch('/api/trigger/' + type, { method: 'POST' })
        const data = await resp.json()
        if (!resp.ok) {
          alert(data.error || 'Trigger failed')
          if (btn) btn.disabled = false
        } else {
          if (data.runId) openLog(data.runId, type)
          if (btn) btn.disabled = false
        }
      } catch (err) {
        alert('Trigger error: ' + err.message)
        if (btn) btn.disabled = false
      }
    }

    // ── Live log ──────────────────────────────────────────────────────────────
    let _liveLogSource = null

    function openLog(runId, label) {
      const panel = document.getElementById('live-log')
      const title = document.getElementById('live-log-title')
      const output = document.getElementById('live-log-output')
      const statusEl = document.getElementById('live-log-status')
      if (!panel) return

      if (_liveLogSource) { _liveLogSource.close(); _liveLogSource = null }

      panel.style.display = 'flex'
      title.textContent = (label || 'run') + ' #' + runId
      output.textContent = ''
      statusEl.textContent = 'running'
      statusEl.className = 'badge badge-running'

      const es = new EventSource('/api/runs/' + runId + '/stream')
      _liveLogSource = es

      es.onmessage = (e) => {
        if (e.data === '[DONE]') {
          es.close()
          _liveLogSource = null
          fetch('/api/runs/' + runId)
            .then(r => r.json())
            .then(d => {
              statusEl.textContent = d.status
              statusEl.className = 'badge badge-' + d.status
              refreshDashboardPanels()
            }).catch(() => {})
          return
        }
        try {
          const parsed = JSON.parse(e.data)
          if (parsed.text) {
            output.textContent += parsed.text
            output.scrollTop = output.scrollHeight
          }
          if (parsed.error) {
            output.textContent += '\n[error] ' + parsed.error
            statusEl.textContent = 'error'
            statusEl.className = 'badge badge-error'
            es.close()
            _liveLogSource = null
          }
        } catch {}
      }

      es.onerror = () => {
        statusEl.textContent = 'disconnected'
        statusEl.className = 'badge badge-error'
        es.close()
        _liveLogSource = null
      }
    }

    function closeLiveLog() {
      if (_liveLogSource) { _liveLogSource.close(); _liveLogSource = null }
      const panel = document.getElementById('live-log')
      if (panel) panel.style.display = 'none'
    }
  </script>
</body>
</html>
