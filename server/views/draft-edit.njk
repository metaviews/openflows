{% extends "base.njk" %}
{% block title %}Draft: {{ draft.title or draft.id }}{% endblock %}

{% block content %}
<div class="page-container">
  <div class="page-header">
    <div>
      <span class="page-title">{{ draft.title or draft.id }}</span>
      <span style="margin-left:0.5rem">
        <span class="badge badge-{{ draft.type or 'unknown' }}">{{ draft.type or '?' }}</span>
        <span class="badge badge-{{ lang }}">{{ lang }}</span>
        <span class="badge badge-{{ draft.status }}">{{ draft.status }}</span>
      </span>
      <div class="muted" style="font-size:0.7rem;margin-top:0.2rem">{{ draft.id }}</div>
    </div>
    <a href="/" class="btn">← Dashboard</a>
  </div>

  <div class="edit-actions">
    <button class="btn btn-primary" onclick="saveDraft()">Save Draft</button>
    <button class="btn" onclick="validateDraft()">Validate</button>
    <button class="btn btn-promote" onclick="confirmPromoteDraft()">Promote to src/</button>
    <button class="btn btn-reject" onclick="rejectDraft()">Reject</button>
    <span id="save-status" class="muted"></span>
  </div>

  <div class="editor-grid">
    <textarea id="draft-content" class="entry-editor">{{ draft.content }}</textarea>
    <aside class="editor-side">
      <div id="validation-panel" class="validation-box">Validation not run yet.</div>
      <div class="panel" style="margin-top:1rem">
        <div class="panel-header"><span class="panel-title">Preview</span></div>
        <div id="draft-preview-body" class="panel-body preview-body"></div>
      </div>
    </aside>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => { renderDraftPreview(); validateDraft() })
document.addEventListener('input', (event) => {
  if (event.target && event.target.id === 'draft-content') renderDraftPreview()
})

function renderDraftPreview() {
  const raw = document.getElementById('draft-content').value
  const body = raw.replace(/^---[\s\S]*?---\s*/, '')
  const preview = document.getElementById('draft-preview-body')
  if (typeof renderMarkdownInto === 'function') renderMarkdownInto(preview, body)
  else preview.textContent = body
}

async function validateDraft() {
  const content = document.getElementById('draft-content').value
  const panel = document.getElementById('validation-panel')
  panel.textContent = 'Validating...'
  const resp = await fetch('/api/queue/{{ draft.id }}/validate?lang={{ lang }}', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ content })
  })
  const data = await resp.json()
  panel.innerHTML = ''
  panel.appendChild(renderValidationBlock(data))
  return data
}

async function saveDraft() {
  const content = document.getElementById('draft-content').value
  const status = document.getElementById('save-status')
  status.textContent = 'Saving...'
  try {
    const resp = await fetch('/api/queue/{{ draft.id }}/update?lang={{ lang }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content })
    })
    const data = await resp.json()
    if (!resp.ok) { status.textContent = 'Error: ' + (data.error || resp.statusText); return }
    status.textContent = 'Saved.'
  } catch (err) {
    status.textContent = 'Error: ' + err.message
  }
}

async function confirmPromoteDraft() {
  const validation = await validateDraft()
  const body = 'Promote {{ draft.id }} ({{ lang }}) to src, commit, and push. Validation: ' + validation.counts.error + ' error(s), ' + validation.counts.warning + ' warning(s).'
  confirmAction({ title: 'Promote Draft', body, confirmText: 'Promote', onConfirm: promoteDraft })
}

async function promoteDraft() {
  const status = document.getElementById('save-status')
  // Save first, then promote.
  const content = document.getElementById('draft-content').value
  status.textContent = 'Saving...'
  try {
    const saveResp = await fetch('/api/queue/{{ draft.id }}/update?lang={{ lang }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content })
    })
    if (!saveResp.ok) { status.textContent = 'Save failed'; return }

    status.textContent = 'Promoting...'
    const resp = await fetch('/api/queue/{{ draft.id }}/promote?lang={{ lang }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: '{}'
    })
    const data = await resp.json()
    if (!resp.ok) { status.textContent = 'Error: ' + (data.error || resp.statusText); return }
    status.textContent = 'Promoted. Returning to dashboard...'
    setTimeout(() => { window.location.href = '/' }, 1200)
  } catch (err) {
    status.textContent = 'Error: ' + err.message
  }
}

async function rejectDraft() {
  confirmAction({
    title: 'Reject Draft',
    body: 'Reject {{ draft.id }} ({{ lang }}) and keep it in the database audit trail.',
    confirmText: 'Reject',
    onConfirm: performRejectDraft
  })
}

async function performRejectDraft() {
  const status = document.getElementById('save-status')
  status.textContent = 'Rejecting...'
  try {
    const resp = await fetch('/api/queue/{{ draft.id }}/reject?lang={{ lang }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: '{}'
    })
    if (!resp.ok) { status.textContent = 'Reject failed'; return }
    window.location.href = '/'
  } catch (err) {
    status.textContent = 'Error: ' + err.message
  }
}
</script>
{% endblock %}
