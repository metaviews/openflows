{% extends "base.njk" %}

{% block content %}
<script>window.OPENFLOWS_IDS = {{ manifestIdsJson | safe }}</script>
<div class="layout">

  <div class="col-full">
    {% include "partials/epistemic.njk" %}
  </div>

  <div class="col-full ops-grid">
    <div class="ops-status">
      {% include "partials/status.njk" %}
    </div>
    <div class="ops-triggers">
      {% include "partials/triggers.njk" %}
    </div>
    <div class="ops-log">
      <div id="live-log">
        <div class="live-log-header">
          <span id="live-log-title" class="live-log-title">Log</span>
          <div style="display:flex;gap:0.5rem;align-items:center">
            <span id="live-log-status" class="badge"></span>
            <button onclick="closeLiveLog()" class="live-log-close">x</button>
          </div>
        </div>
        <pre id="live-log-output"></pre>
      </div>
    </div>
  </div>

  <div class="col-full workbench-grid">
    <section class="workbench-main">
      {% include "partials/queue.njk" %}
      {% include "partials/conversations.njk" %}
      <div id="draft-preview" class="panel" style="display:none"></div>
    </section>

    <aside class="workbench-ops">
      {% include "partials/activity.njk" %}
      {% include "partials/timeline.njk" %}
    </aside>
  </div>

</div>
{% endblock %}
