{% extends "base.njk" %}
{% block title %}{{ entry.title }}{% endblock %}

{% block content %}
<div class="page-container">
  <div class="page-header">
    <div>
      <span class="page-title">{{ entry.title }}</span>
      <span style="margin-left:0.5rem">
        <span class="badge badge-{{ entry.currencyType }}">{{ entry.currencyType }}</span>
        <span class="badge badge-{{ lang }}">{{ lang }}</span>
      </span>
      <div class="muted" style="font-size:0.7rem;margin-top:0.2rem">{{ relPath }}</div>
    </div>
    <a href="/entries?lang={{ lang }}" class="btn">← Back</a>
  </div>

  <div class="edit-actions">
    <button class="btn btn-primary" onclick="confirmSaveEntry()">Save &amp; Commit</button>
    <button class="btn" onclick="validateEntry()">Validate</button>
    <button class="btn btn-danger" onclick="deleteEntry()">Delete</button>
    <span id="save-status" class="muted"></span>
  </div>

  <div class="editor-grid">
    <textarea id="entry-content" class="entry-editor">{{ content }}</textarea>
    <aside class="editor-side">
      <div id="validation-panel" class="validation-box">Validation not run yet.</div>
      <div class="panel" style="margin-top:1rem">
        <div class="panel-header"><span class="panel-title">Preview</span></div>
        <div id="entry-preview" class="panel-body preview-body"></div>
      </div>
    </aside>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => { renderEntryPreview(); validateEntry() })
document.addEventListener('input', (event) => {
  if (event.target && event.target.id === 'entry-content') renderEntryPreview()
})

function renderEntryPreview() {
  const raw = document.getElementById('entry-content').value
  const body = raw.replace(/^---[\s\S]*?---\s*/, '')
  const preview = document.getElementById('entry-preview')
  if (typeof renderMarkdownInto === 'function') renderMarkdownInto(preview, body)
  else preview.textContent = body
}

async function validateEntry() {
  const content = document.getElementById('entry-content').value
  const panel = document.getElementById('validation-panel')
  panel.textContent = 'Validating...'
  const resp = await fetch('/api/entries/{{ entry.currencyId }}/validate?lang={{ lang }}', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ content })
  })
  const data = await resp.json()
  panel.innerHTML = ''
  panel.appendChild(renderValidationBlock(data))
  return data
}

async function confirmSaveEntry() {
  const validation = await validateEntry()
  const body = 'Save {{ entry.currencyId }} ({{ lang }}) to src, commit the edit, and push to GitHub. Validation: ' + validation.counts.error + ' error(s), ' + validation.counts.warning + ' warning(s).'
  confirmAction({ title: 'Save & Commit', body, confirmText: 'Save & Commit', onConfirm: saveEntry })
}

async function saveEntry() {
  const content = document.getElementById('entry-content').value
  const status = document.getElementById('save-status')
  status.textContent = 'Saving...'
  try {
    const resp = await fetch('/api/entries/{{ entry.currencyId }}/save?lang={{ lang }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content })
    })
    const data = await resp.json()
    if (!resp.ok) { status.textContent = 'Error: ' + (data.error || resp.statusText); return }
    status.textContent = data.committed ? 'Saved and committed.' : 'Saved (no changes detected).'
  } catch (err) {
    status.textContent = 'Error: ' + err.message
  }
}

async function deleteEntry() {
  confirmAction({
    title: 'Delete Entry',
    body: 'Delete {{ entry.currencyId }} ({{ lang }}) from src, commit, and push. This cannot be undone from the dashboard.',
    confirmText: 'Delete',
    onConfirm: performDeleteEntry
  })
}

async function performDeleteEntry() {
  const status = document.getElementById('save-status')
  status.textContent = 'Deleting...'
  try {
    const resp = await fetch('/api/entries/{{ entry.currencyId }}/delete?lang={{ lang }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: '{}'
    })
    const data = await resp.json()
    if (!resp.ok) { status.textContent = 'Error: ' + (data.error || resp.statusText); return }
    window.location.href = '/entries'
  } catch (err) {
    status.textContent = 'Error: ' + err.message
  }
}
</script>
{% endblock %}
